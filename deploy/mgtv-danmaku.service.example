[Unit]
Description=MGTV Danmaku Vote Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mgtv-vote
Group=mgtv-vote
WorkingDirectory=/opt/MangoTV_Danmaku
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/MangoTV_Danmaku/.venv/bin/python server/vote_server.py --config server/config.json
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/MangoTV_Danmaku/server/data

[Install]
WantedBy=multi-user.target
